# PredictBot — Environment Variables
# Copy this file to .env and fill in your keys:  cp .env.example .env
#
# Required keys are marked with [REQUIRED]. Everything else is optional
# but improves analysis quality or enables specific features.

# ─── AI / LLM ───────────────────────────────────────────────────────
# [REQUIRED] Claude API key — powers all market analysis
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter key — enables multi-model ensemble (GPT-4o, Gemini, DeepSeek)
# Get one free at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-...

# ─── Kalshi (Prediction Exchange) ───────────────────────────────────
# API Key ID and RSA private key for authenticated trading
# Generate at https://kalshi.com/account/api
KALSHI_API_KEY_ID=your-kalshi-key-id
KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# ─── Polymarket (Prediction Exchange) ──────────────────────────────
# Only needed if you trade on Polymarket. Derived from your wallet.
# Use /api/derive-keys endpoint or set manually.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# ─── News & Search (Free) ──────────────────────────────────────────
# Brave Search API — provides real-time news context for analysis
# Get a free key at https://brave.com/search/api/
BRAVE_API_KEY=BSA...

# Google Custom Search — fallback if Brave is unavailable
# https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_KEY=
GOOGLE_CX=

# ─── Data Sources (Free) ───────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — CPI, unemployment, GDP, rates
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-key

# ─── Data Sources (Paid) ──────────────────────────────────────────
# The Odds API — live bookmaker odds for sports markets
# Free tier: 500 requests/month. https://the-odds-api.com/
ODDS_API_KEY=your-odds-api-key

# API-Sports — injury data, lineups, predictions ($10/mo)
# https://api-sports.io/
API_SPORTS_KEY=

# ─── Bot Settings ──────────────────────────────────────────────────
# Minutes between autopilot trading cycles (default: 20)
CYCLE_INTERVAL_MIN=20

# Server URL the autopilot connects to (default: http://localhost:3000)
SERVER_URL=http://localhost:3000

# Port for the local dev server (default: 3000)
PORT=3000

# Set to "false" to disable the meta-agent strategy optimizer
META_AGENT_ENABLED=true
